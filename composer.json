{
  "name": "falter-verlag/socialite-provider-remp",
  "description": "REMP OAuth 2.0 Client Provider for Laravel Socialite",
  "license": "MIT",
  "authors": [],
  "keywords": [],
  "require": {
    "php": "^8.0",
    "illuminate/support": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
    "laravel/socialite": "^5.2"
  },
  "require-dev": {
    "larastan/larastan": "^2.9|^3.0",
    "laravel/pint": "^1.0",
    "mockery/mockery": "^1.0",
    "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^8.0|^9.3|^10.4|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Remp\\Auth\\Socialite\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "format": "pint",
    "analyse": "phpstan analyse"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Remp\\Auth\\Socialite\\ServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
